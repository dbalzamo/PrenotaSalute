# Copia questo file come .env nella cartella PrenotaSalute-BE (stessa directory del pom.xml).
# Non committare .env.

# JWT: stringa Base64 che decodifica in almeno 32 byte (come richiesto da JwtService).
# Generazione esempio: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRATION_MS=900000

DB_URL=jdbc:mysql://localhost:3306/hospital_book_management?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=
DB_PASSWORD=
